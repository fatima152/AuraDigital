# Aura Digital — Backend Configuration
# Copy this file to .env and fill in your values

# Server Port
PORT=5000

# Gmail SMTP — Enable 2FA & create App Password: https://myaccount.google.com/apppasswords
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-16-character-app-password

# Production: set to "production" to serve frontend build
NODE_ENV=development
